generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model QueueEntry {
  id           Int      @id @default(autoincrement())
  ticketNumber String   @unique
  peopleCount  Int
  phoneNumber  String
  status       String   @default("WAITING")
  position     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
